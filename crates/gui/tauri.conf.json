{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "rivet",
  "version": "0.1.0",
  "identifier": "com.rivet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "./dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rivet - API Testing",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Development",
    "shortDescription": "REST API testing framework",
    "longDescription": "Rivet is a powerful REST API testing framework with both GUI and CLI interfaces. Write tests in YAML, execute them, and view detailed results.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [],
        "priority": "optional",
        "section": "devel"
      },
      "rpm": {
        "depends": []
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBRUJFRTkyODgwM0I3MTkKUldRWnR3T0lrdTdyYW44RTNmbnVxTlNyeVNZT2x0cmtyVzBpdzV4UkdEMWFlNGFKSU5FQjRkYTcK"
    }
  }
}